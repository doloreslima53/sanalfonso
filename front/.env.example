# ── Proxy del backend (Docker Compose / dev local) ─────────
# URL interna a la que Vite hace proxy de /api y /uploads
# Local sin Docker: dejar vacío (usa http://localhost:8000 por defecto)
# Con Docker Compose: BACKEND_URL=http://back:8000
BACKEND_URL=http://back:8000

# ── URL directa del backend (Railway / producción) ─────────
# Si está definida, el cliente axios llama directo al backend sin pasar por el proxy.
# Dejar vacío en Docker/dev local.
# VITE_BACKEND_URL=https://tu-backend.railway.app

# ── Vite dev server ────────────────────────────────────────
# Separar múltiples hosts con coma
ALLOWED_HOSTS=sanalfonsofrontend-production.up.railway.app
