# ── Aplicación ────────────────────────────────────────────
APP_ENV=development          # development | production
DEBUG=true

# ── Base de datos (PostgreSQL) ─────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=geriatrico
DB_USER=geriatrico_user
DB_PASSWORD=changeme

# Construida automáticamente en el código a partir de las vars anteriores;
# también podés setearla directamente para sobreescribir:
# DATABASE_URL=postgresql+asyncpg://geriatrico_user:changeme@db:5432/geriatrico

# ── CORS ───────────────────────────────────────────────────
# Separar múltiples orígenes con coma
CORS_ORIGINS=http://localhost:5173
